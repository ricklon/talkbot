{
    "_comment": "Local vs remote comparison matrix. Local = llama-server on control node (x86_64 CPU). Remote = OpenRouter API. Run with: uv run python scripts/benchmark_conversations.py --matrix benchmarks/model_matrix.local-vs-remote.json",
    "benchmark": {
        "schema_version": "2026.1",
        "values_file": "benchmarks/evaluation_values.json",
